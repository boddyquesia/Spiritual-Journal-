{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier for the user"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address"
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The date and time the user was created"
        }
      },
      "required": ["uid", "email"]
    },
    "DailyNote": {
      "title": "Daily Note",
      "description": "A daily spiritual note entry",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "bibleText": { "type": "string" },
        "comments": { "type": "string" },
        "explanation": { "type": "string" },
        "bibleReading": { "type": "string" },
        "spiritualGems": { "type": "string" },
        "status": { "type": "string", "enum": ["empty", "partial", "completed"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "date"]
    },
    "Experience": {
      "title": "Service Experience",
      "description": "A personal service experience entry",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "description": { "type": "string" },
        "images": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "date", "description"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "The user's profile information"
    },
    "/dailyNotes/{noteId}": {
      "schema": "DailyNote",
      "description": "Daily spiritual notes"
    },
    "/experiences/{experienceId}": {
      "schema": "Experience",
      "description": "Service experiences"
    }
  }
}
